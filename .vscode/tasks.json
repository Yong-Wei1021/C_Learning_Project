{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-I", "${workspaceFolder}/include", // 加上 include 目錄，讓編譯器能找到 .h檔
                "-o", "${fileDirname}/${fileBasenameNoExtension}.out", // 執行檔一律加上 .out
                "-Wall" // 顯示所有警告訊息
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "編譯器: /usr/bin/gcc"
        }
    ]
}